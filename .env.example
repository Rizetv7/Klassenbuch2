# Copy this file to ".env" and fill in the values.
#
# The app uses PostgreSQL (Supabase / Neon / Railway). The easiest way to get
# the two URLs below is the Supabase dashboard:
#   Connect (top of page)  ->  ORM  ->  Prisma
# Supabase shows you exactly these two values, ready to copy.

# Runtime connection — Supabase "Transaction" pooler (port 6543).
# Must include ?pgbouncer=true at the end.
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432) — used to create/update tables (db push).
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Secret used to sign login sessions. Generate a strong random value, e.g.:
#   openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Image uploads (profile pictures & photos) ---
# Needed in production so uploads land in durable Supabase Storage instead of
# the (read-only) serverless filesystem. Create a PUBLIC bucket named "uploads".
#   SUPABASE_URL: Supabase -> Settings -> Data API -> Project URL
#   SUPABASE_SERVICE_ROLE_KEY: Supabase -> Settings -> API Keys -> service_role
#   (the service_role key is secret — only ever set it as a server env var)
SUPABASE_URL="https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ...the-service-role-key..."
