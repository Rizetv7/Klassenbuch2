# Copy this file to ".env" and fill in the values.
#
# The app uses PostgreSQL (Supabase / Neon / Railway). Get the URL from the
# Supabase dashboard: Connect (top) -> ORM -> Prisma -> the DATABASE_URL line.
#
# Tables are created once by running db/schema.sql in the Supabase SQL Editor
# (the build itself no longer touches the database, so it can't fail on it).

# Runtime connection — Supabase "Transaction" pooler (port 6543).
# Must include ?pgbouncer=true at the end.
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Secret used to sign login sessions. Generate a strong random value, e.g.:
#   openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Optional internal admin access. ADMIN_PASSWORD_HASH must be a bcrypt hash,
# never a plaintext password. ADMIN_AUTH_SECRET may be different from the
# normal session secret; if omitted, AUTH_SECRET is used.
ADMIN_USERNAME="archiv-admin"
ADMIN_PASSWORD_HASH="$2a$12$replace-with-a-bcrypt-hash"
ADMIN_AUTH_SECRET="change-me-to-another-long-random-string"

# --- Image uploads (profile pictures & photos) ---
# Needed in production so uploads land in durable Supabase Storage instead of
# the (read-only) serverless filesystem. Create a PUBLIC bucket named "uploads".
#   SUPABASE_URL: Supabase -> Settings -> Data API -> Project URL
#   SUPABASE_SERVICE_ROLE_KEY: Supabase -> Settings -> API Keys -> service_role
#   (the service_role key is secret — only ever set it as a server env var)
SUPABASE_URL="https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ...the-service-role-key..."
