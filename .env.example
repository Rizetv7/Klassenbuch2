# Copy this file to ".env" and fill in the values.

# --- Local development (SQLite, no setup required) ---
DATABASE_URL="file:./dev.db"

# --- Production (PostgreSQL, e.g. Supabase / Neon / Railway) ---
# Switch prisma/schema.prisma provider to "postgresql" and use a URL like:
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret used to sign login sessions. Generate a strong random value, e.g.:
#   openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
