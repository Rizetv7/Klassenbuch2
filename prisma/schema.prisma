// Prisma schema for the Maturaziitig app.
//
// Local development uses SQLite (zero setup). For production switch the
// provider to "postgresql" and point DATABASE_URL at a managed Postgres
// (Supabase / Neon / Railway). The models below work with both.
//
// NOTE: SQLite has no native enums, so role / memberType / board / kind are
// stored as plain strings. Allowed values are documented next to each field.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Supabase connection string (Connect -> ORM -> Prisma). The transaction
  // pooler (port 6543, ?pgbouncer=true) is ideal for serverless runtime.
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String   @unique // also used as login handle
  nickname     String?
  email        String?  @unique // optional
  passwordHash String
  avatarUrl    String?
  accentColor  String?  // personal accent color for the avatar ring
  createdAt    DateTime @default(now())

  memberships Membership[]
  posts       Post[]       @relation("PostAuthor")
  comments    Comment[]
  likes       Like[]
  ownedClasses Class[]     @relation("ClassOwner")
  topics      Topic[]      @relation("TopicCreator")
  teachers    Teacher[]    @relation("TeacherCreator")
}

model Class {
  id          String   @id @default(cuid())
  name        String
  description String?
  school      String?
  gradYear    String?
  joinCode    String   @unique
  ownerId     String
  createdAt   DateTime @default(now())

  owner       User         @relation("ClassOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships Membership[]
  posts       Post[]
  topics      Topic[]
  teachers    Teacher[]
}

// A teacher is NOT an account/member. Students create teacher entries inside
// their class, give them a picture, and post quotes/images about them.
model Teacher {
  id          String   @id @default(cuid())
  classId     String
  name        String
  subject     String?
  avatarUrl   String?
  accentColor String?
  createdById String
  createdAt   DateTime @default(now())

  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  creator User  @relation("TeacherCreator", fields: [createdById], references: [id], onDelete: Cascade)
  posts   Post[]

  @@index([classId])
}

// A class-wide collection / project (e.g. "Ausflug", "Maturaball"). Holds
// posts (images, quotes, notes) that are general to the class rather than
// tied to one person.
model Topic {
  id          String   @id @default(cuid())
  classId     String
  name        String
  createdById String
  createdAt   DateTime @default(now())

  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  creator User  @relation("TopicCreator", fields: [createdById], references: [id], onDelete: Cascade)
  posts   Post[]

  @@index([classId])
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  classId     String
  role        String   @default("MEMBER")  // OWNER | MODERATOR | MEMBER
  memberType  String   @default("STUDENT") // STUDENT | TEACHER
  displayName String                       // name shown inside this class
  createdAt   DateTime @default(now())

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  // Posts where this membership is the "subject" (whose yearbook page it is on)
  subjectPosts Post[] @relation("PostSubject")

  @@unique([userId, classId])
}

model Post {
  id                 String   @id @default(cuid())
  classId            String
  authorId           String
  subjectMembershipId String?  // student the post is about
  teacherId          String?   // teacher the post is about
  topicId            String?   // topic/project the post belongs to
  board              String   @default("YEARBOOK") // YEARBOOK | TOPIC
  kind               String   @default("QUOTE")    // QUOTE | IMAGE | TEXT (note)
  text               String?
  context            String?  // optional context, e.g. "vor der Matheprüfung"
  saidByName         String?  // who said the quote (used in projects)
  anonymous          Boolean  @default(false) // hide the author
  imageUrl           String?
  createdAt          DateTime @default(now())

  class    Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  author   User        @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  subject  Membership? @relation("PostSubject", fields: [subjectMembershipId], references: [id], onDelete: Cascade)
  teacher  Teacher?    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  topic    Topic?      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]

  @@index([classId])
  @@index([subjectMembershipId])
  @@index([teacherId])
  @@index([topicId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  text      String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}
